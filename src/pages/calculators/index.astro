---
import MainLayout from "@/layouts/MainLayout.astro";
import ToolGrid from "@/components/ToolGrid";
import { availableTools } from "@/contexts/toolsData";
import { buildCollectionSchema } from "@/lib/schema";

const title = "Free Online Calculators | ToolNames";
const description = "Browse 30+ free calculators for finance, health, math, and more. Mortgage, BMI, compound interest, tip, and retirement calculators — all private, browser-based.";
const categoryTools = availableTools.filter((t) => t.category === "calculators");

const collectionSchema = buildCollectionSchema(title, description, "https://toolnames.com/calculators", categoryTools);
---

<MainLayout
  title={title}
  description={description}
  jsonLd={collectionSchema}
>
  <ToolGrid initialCategory="calculators" client:only="react" />
</MainLayout>
