---
import MainLayout from "@/layouts/MainLayout.astro";
import ToolGrid from "@/components/ToolGrid";
import { availableTools } from "@/contexts/toolsData";

const title = "Free SEO Analysis Tools | ToolNames";
const description = "Analyze keyword density, meta tags, heading structure, alt text, and internal links to improve your site's SEO — all private and browser-based.";
const categoryTools = availableTools.filter((t) => t.category === "seo");

const collectionSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": "https://toolnames.com/seo",
  "hasPart": categoryTools.map((t) => ({
    "@type": "SoftwareApplication",
    "name": t.title,
    "url": `https://toolnames.com${t.url}`,
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Web Browser",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  }))
});
---

<MainLayout
  title={title}
  description={description}
  jsonLd={collectionSchema}
>
  <ToolGrid initialCategory="seo" client:only="react" />
</MainLayout>
