---
import MainLayout from "@/layouts/MainLayout.astro";
import ToolGrid from "@/components/ToolGrid";
import { availableTools } from "@/contexts/toolsData";

const title = "Color Theory Tools | ToolNames";
const description = "Explore color theory concepts: color wheels, harmonies, contrast ratios, palette building, and color blindness simulation — all interactive and browser-based.";
const categoryTools = availableTools.filter((t) => t.category === "color-theory");

const collectionSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": "https://toolnames.com/color-theory",
  "hasPart": categoryTools.map((t) => ({
    "@type": "SoftwareApplication",
    "name": t.title,
    "url": `https://toolnames.com${t.url}`,
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Web Browser",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  }))
});
---

<MainLayout
  title={title}
  description={description}
  jsonLd={collectionSchema}
>
  <ToolGrid initialCategory="color-theory" client:only="react" />
</MainLayout>
