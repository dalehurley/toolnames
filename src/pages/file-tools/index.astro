---
import MainLayout from "@/layouts/MainLayout.astro";
import ToolGrid from "@/components/ToolGrid";
import { availableTools } from "@/contexts/toolsData";
import { buildCollectionSchema } from "@/lib/schema";

const title = "Free File & Image Tools | ToolNames";
const description = "Convert images between JPG, PNG, WebP, GIF. Explore CSV data, view image metadata, convert audio files — all processing done locally in your browser.";
const categoryTools = availableTools.filter((t) => t.category === "file-tools");

const collectionSchema = buildCollectionSchema(title, description, "https://toolnames.com/file-tools", categoryTools);
---

<MainLayout
  title={title}
  description={description}
  jsonLd={collectionSchema}
>
  <ToolGrid initialCategory="file-tools" client:only="react" />
</MainLayout>
