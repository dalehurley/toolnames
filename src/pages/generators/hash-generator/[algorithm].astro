---
import type { GetStaticPaths } from "astro";
import MainLayout from "@/layouts/MainLayout.astro";
import { HashGenerator } from "@/components/tools/generators/HashGenerator";
import { hashAlgorithms, hashAlgorithmMeta } from "@/data/hashAlgorithms";

export const getStaticPaths: GetStaticPaths = () => {
  return hashAlgorithms.map((algorithm) => ({
    params: { algorithm },
    props: { algorithm, ...hashAlgorithmMeta[algorithm] },
  }));
};

const { algorithm, pageTitle, metaDescription } = Astro.props;

const toolSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": `${algorithm.toUpperCase()} Hash Generator`,
  "description": metaDescription,
  "url": `https://toolnames.com/generators/hash-generator/${algorithm}`,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web Browser",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
});
---

<MainLayout title={pageTitle} description={metaDescription} jsonLd={toolSchema}>
  <HashGenerator initialAlgorithm={algorithm} client:only="react" />
</MainLayout>
