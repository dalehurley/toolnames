---
import MainLayout from "@/layouts/MainLayout.astro";
import ToolGrid from "@/components/ToolGrid";
import { availableTools } from "@/contexts/toolsData";
import { buildCollectionSchema } from "@/lib/schema";

const title = "Free Online Generators | ToolNames";
const description = "Generate passwords, QR codes, UUIDs, hashes, Lorem Ipsum text, random numbers, ASCII art, and color palettes. Free, secure, and browser-based.";
const categoryTools = availableTools.filter((t) => t.category === "generators");

const collectionSchema = buildCollectionSchema(title, description, "https://toolnames.com/generators", categoryTools);
---

<MainLayout
  title={title}
  description={description}
  jsonLd={collectionSchema}
>
  <ToolGrid initialCategory="generators" client:only="react" />
</MainLayout>
