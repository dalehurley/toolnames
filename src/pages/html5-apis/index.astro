---
import MainLayout from "@/layouts/MainLayout.astro";
import ToolGrid from "@/components/ToolGrid";
import { availableTools } from "@/contexts/toolsData";
import { buildCollectionSchema } from "@/lib/schema";

const title = "Free HTML5 API Demo Tools | ToolNames";
const description = "Interactive demos for Web Audio, Geolocation, MediaRecorder, Canvas, Notifications, Clipboard, Device Orientation, and other browser APIs.";
const categoryTools = availableTools.filter((t) => t.category === "html5-apis");

const collectionSchema = buildCollectionSchema(title, description, "https://toolnames.com/html5-apis", categoryTools);
---

<MainLayout
  title={title}
  description={description}
  jsonLd={collectionSchema}
>
  <ToolGrid initialCategory="html5-apis" client:only="react" />
</MainLayout>
