---
import MainLayout from "@/layouts/MainLayout.astro";
import ToolGrid from "@/components/ToolGrid";
import { availableTools } from "@/contexts/toolsData";

const title = "Free Online Converters | ToolNames";
const description = "Convert units, colors, images, audio, files, number bases, and more. All converters run in your browser — no uploads, no data sharing.";
const categoryTools = availableTools.filter((t) => t.category === "converters");

const collectionSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": "https://toolnames.com/converters",
  "hasPart": categoryTools.map((t) => ({
    "@type": "SoftwareApplication",
    "name": t.title,
    "url": `https://toolnames.com${t.url}`,
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Web Browser",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  }))
});
---

<MainLayout
  title={title}
  description={description}
  jsonLd={collectionSchema}
>
  <ToolGrid initialCategory="converters" client:only="react" />
</MainLayout>
