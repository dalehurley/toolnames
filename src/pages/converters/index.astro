---
import MainLayout from "@/layouts/MainLayout.astro";
import ToolGrid from "@/components/ToolGrid";
import { availableTools } from "@/contexts/toolsData";
import { buildCollectionSchema } from "@/lib/schema";

const title = "Free Online Converters | ToolNames";
const description = "Convert units, colors, images, audio, files, number bases, and more. All converters run in your browser — no uploads, no data sharing.";
const categoryTools = availableTools.filter((t) => t.category === "converters");

const collectionSchema = buildCollectionSchema(title, description, "https://toolnames.com/converters", categoryTools);
---

<MainLayout
  title={title}
  description={description}
  jsonLd={collectionSchema}
>
  <ToolGrid initialCategory="converters" client:only="react" />
</MainLayout>
