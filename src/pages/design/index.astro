---
import MainLayout from "@/layouts/MainLayout.astro";
import ToolGrid from "@/components/ToolGrid";
import { availableTools } from "@/contexts/toolsData";
import { buildCollectionSchema } from "@/lib/schema";

const title = "Free CSS & Design Tools | ToolNames";
const description = "CSS flexbox and grid generators, color palette explorer, gradient builder, animation generator, typography scale, color blindness simulator, and more.";
const categoryTools = availableTools.filter((t) => t.category === "design");

const collectionSchema = buildCollectionSchema(title, description, "https://toolnames.com/design", categoryTools);
---

<MainLayout
  title={title}
  description={description}
  jsonLd={collectionSchema}
>
  <ToolGrid initialCategory="design" client:only="react" />
</MainLayout>
